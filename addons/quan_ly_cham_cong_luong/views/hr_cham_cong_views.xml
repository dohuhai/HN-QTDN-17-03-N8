<odoo>

    <record id="view_hr_cham_cong_tree" model="ir.ui.view">
        <field name="name">hr_cham_cong_tree</field>
        <field name="model">hr_cham_cong</field>
        <field name="arch" type="xml">
            <tree string="Dữ liệu chấm công">
                <field name="ngay_cham_cong"/>
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="trang_thai"/>
                <field name="so_gio_lam_viec"/>
                <field name="so_gio_tang_ca"/>
                <field name="nguoi_xac_nhan"/>
                <button name="action_chot_cong_thang"
                        string="Chốt công"
                        type="object"
                        class="btn-primary"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_cham_cong_form" model="ir.ui.view">
        <field name="name">hr_cham_cong_form</field>
        <field name="model">hr_cham_cong</field>
        <field name="arch" type="xml">
            <form string="Dữ liệu chấm công">
                <header>
                    <button name="action_chot_cong_thang"
                            string="Chốt công tháng"
                            type="object"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <group string="Thông tin nhân viên">
                            <field name="nhan_vien_id"/>
                            <field name="ma_dinh_danh" readonly="1"/>
                            <field name="ngay_cham_cong"/>
                        </group>

                        <group string="Thông tin chấm công">
                            <field name="trang_thai"/>
                            <field name="so_gio_lam_viec" readonly="1"/>
                            <field name="so_gio_tang_ca"/>
                            <field name="nguoi_xac_nhan"/>
                        </group>
                    </group>

                    <group string="Ghi chú">
                        <field name="ghi_chu"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_cham_cong_search" model="ir.ui.view">
        <field name="name">hr_cham_cong_search</field>
        <field name="model">hr_cham_cong</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm chấm công">
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="ngay_cham_cong"/>
                <field name="trang_thai"/>

                <filter string="Đi làm đủ ngày" name="filter_di_lam_du_ngay" domain="[('trang_thai','=','di_lam_du_ngay')]"/>
                <filter string="Làm nửa ngày" name="filter_lam_nua_ngay" domain="[('trang_thai','=','lam_nua_ngay')]"/>
                <filter string="Nghỉ có phép" name="filter_nghi_co_phep" domain="[('trang_thai','=','nghi_co_phep')]"/>
                <filter string="Nghỉ không phép" name="filter_nghi_khong_phep" domain="[('trang_thai','=','nghi_khong_phep')]"/>

                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên" name="group_nhan_vien" context="{'group_by':'nhan_vien_id'}"/>
                    <filter string="Ngày" name="group_ngay" context="{'group_by':'ngay_cham_cong'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_cham_cong" model="ir.actions.act_window">
        <field name="name">Dữ liệu chấm công</field>
        <field name="res_model">hr_cham_cong</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_cham_cong_search"/>
    </record>

</odoo>
