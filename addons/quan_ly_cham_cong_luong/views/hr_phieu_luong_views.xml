<odoo>

    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr_phieu_luong_tree</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <tree string="Phiếu lương tháng">
                <field name="ten_phieu_luong"/>
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="thang"/>
                <field name="nam" options="{'format': false}"/>
                <field name="so_ngay_cong_tinh_luong"/>
                <field name="luong_co_ban"/>
                <field name="phu_cap"/>
                <field name="tong_khen_thuong"/>
                <field name="tong_ky_luat"/>
                <field name="tien_bao_hiem"/>
                <field name="thuc_linh"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr_phieu_luong_form</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <form string="Phiếu lương tháng">
                <header>
                    <button name="action_xac_nhan"
                            string="Xác nhận"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>

                    <button name="action_thanh_toan"
                            string="Thanh toán"
                            type="object"
                            class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'xac_nhan')]}"/>

                    <button name="action_dua_ve_nhap"
                            string="Đưa về nháp"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '=', 'nhap')]}"/>

                    <field name="trang_thai"
                           widget="statusbar"
                           statusbar_visible="nhap,xac_nhan,thanh_toan"/>
                </header>

                <sheet>
                    <group>
                        <group string="Thông tin phiếu lương">
                            <field name="ten_phieu_luong"/>
                            <field name="nhan_vien_id"/>
                            <field name="ma_dinh_danh" readonly="1"/>
                            <field name="thang"/>
                            <field name="nam" options="{'format': false}"/>
                        </group>

                        <group string="Thông tin công">
                            <field name="so_ngay_cong_tinh_luong"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Chi tiết lương">
                            <group>
                                <group string="Khoản cộng">
                                    <field name="luong_co_ban"/>
                                    <field name="phu_cap"/>
                                    <field name="tong_khen_thuong"/>
                                </group>

                                <group string="Khoản trừ">
                                    <field name="tong_ky_luat"/>
                                    <field name="tien_bao_hiem"/>
                                </group>
                            </group>
                        </page>

                        <page string="Công thức và kết quả">
                            <group>
                                <group string="Công thức tính">
                                    <div class="o_form_label">
                                        Thực lĩnh = (Lương cơ bản / 26) x Số ngày công + Phụ cấp + Khen thưởng - Kỷ luật - Bảo hiểm
                                    </div>
                                </group>

                                <group string="Kết quả">
                                    <field name="thuc_linh" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Ghi chú">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_phieu_luong_search" model="ir.ui.view">
        <field name="name">hr_phieu_luong_search</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm phiếu lương">
                <field name="ten_phieu_luong"/>
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="trang_thai"/>

                <filter string="Nháp" name="filter_nhap" domain="[('trang_thai','=','nhap')]"/>
                <filter string="Đã xác nhận" name="filter_xac_nhan" domain="[('trang_thai','=','xac_nhan')]"/>
                <filter string="Đã thanh toán" name="filter_thanh_toan" domain="[('trang_thai','=','thanh_toan')]"/>

                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên" name="group_nhan_vien" context="{'group_by':'nhan_vien_id'}"/>
                    <filter string="Tháng" name="group_thang" context="{'group_by':'thang'}"/>
                    <filter string="Năm" name="group_nam" context="{'group_by':'nam'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu lương tháng</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_phieu_luong_search"/>
    </record>

</odoo>
