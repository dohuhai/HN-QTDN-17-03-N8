<odoo>
    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr_phieu_luong_tree</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <tree string="Phiếu lương tháng"
                  decoration-success="trang_thai == 'xac_nhan'"
                  decoration-danger="trang_thai == 'huy'">
                <field name="ten_phieu_luong"/>
                <field name="nhan_vien_id"/>
                <field name="ma_dinh_danh"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="so_ngay_cong_tinh_luong"/>
                <field name="luong_co_ban"/>
                <field name="phu_cap"/>
                <field name="tong_khen_thuong"/>
                <field name="tong_ky_luat"/>
                <field name="tien_bao_hiem"/>
                <field name="tong_thu_nhap"/>
                <field name="thuc_linh"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr_phieu_luong_form</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <form string="Phiếu lương tháng">
                <header>
                    <button name="action_xac_nhan"
                            string="Xác nhận phiếu lương"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>

                    <button name="action_dat_ve_nhap"
                            string="Đưa về nháp"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '!=', 'xac_nhan')]}"/>

                    <button name="action_huy"
                            string="Hủy phiếu"
                            type="object"
                            attrs="{'invisible': [('trang_thai', '=', 'huy')]}"/>

                    <field name="trang_thai"
                           widget="statusbar"
                           statusbar_visible="nhap,xac_nhan,huy"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="ten_phieu_luong"/>
                        <h1>
                            <field name="ten_phieu_luong" readonly="1"/>
                        </h1>
                    </div>

                    <group string="Thông tin phiếu lương">
                        <group>
                            <field name="nhan_vien_id"/>
                            <field name="ma_dinh_danh" readonly="1"/>
                        </group>
                        <group>
                            <field name="thang"/>
                            <field name="nam"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Dữ liệu chấm công">
                            <group>
                                <group string="Ngày công">
                                    <field name="so_ngay_di_lam" readonly="1"/>
                                    <field name="so_ngay_nua_ngay" readonly="1"/>
                                    <field name="so_ngay_cong_tinh_luong" readonly="1"/>
                                </group>

                                <group string="Nghỉ phép và tăng ca">
                                    <field name="so_ngay_nghi_co_phep" readonly="1"/>
                                    <field name="so_ngay_nghi_khong_phep" readonly="1"/>
                                    <field name="tong_gio_tang_ca" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Thu nhập và khấu trừ">
                            <group>
                                <group string="Thu nhập">
                                    <field name="luong_co_ban" readonly="1"/>
                                    <field name="phu_cap" readonly="1"/>
                                    <field name="tong_khen_thuong" readonly="1"/>
                                </group>

                                <group string="Khấu trừ">
                                    <field name="tong_ky_luat" readonly="1"/>
                                    <field name="ty_le_bao_hiem"/>
                                    <field name="tien_bao_hiem" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Kết quả tính lương">
                            <group>
                                <group string="Công thức tính">
                                    <label string="Thực lĩnh = (Lương cơ bản / 26) x Số ngày công + Phụ cấp + Khen thưởng - Kỷ luật - Bảo hiểm"/>
                                </group>

                                <group string="Kết quả">
                                    <field name="tong_thu_nhap" readonly="1"/>
                                    <field name="tien_bao_hiem" readonly="1"/>
                                    <field name="thuc_linh" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Ghi chú">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu lương tháng</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>